# Snippet 5 – Vòng for với range(i) 
def snippet_5(n): 
    total = 0            # 1
    for i in range(n):   # n
        for j in range(i): # ~n/2
            total += 1   # 2
    return total         # 1

# T(n) = n^2 - n + 2 => O(n^2)


# Snippet 6 – Vòng while + for 
def snippet_6(n): 
    k = 1                # 1
    total = 0            # 1
    while k < n:         # log2(n)
        for i in range(n): # n
            total += 1   # 2
        k = k * 2        # 2
    return total         # 1

# T(n) = 2*n*log2(n) + 2*log2(n) + 3 => O(n log n)


# Snippet 7 – Duyệt list + toán tử in (list) 
def snippet_7(arr): 
    count = 0            # 1
    for x in arr:        # n
        if x in arr:     # n
            count += 1   # 2
    return count         # 1

# T(n) = n^2 + 2n + 2 => O(n^2)


# Snippet 8 – Dùng set để tối ưu phép in 
def snippet_8(arr): 
    s = set(arr)         # n
    count = 0            # 1
    for x in arr:        # n
        if x in s:       # 1
            count += 1   # 2
    return count         # 1

# T(n) = 4n + 2 => O(n)


